# Database
DATABASE_URL=

# Node Environment
NODE_ENV=

# Email/SMTP Configuration
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_FROM_NAME=
SMTP_IGNORE_TLS=
SMTP_MAX_RETRIES=
SMTP_TIMEOUT_MS=

# Application URLs
NEXT_PUBLIC_BASE_URL=
NEXT_PUBLIC_APP_URL=
APP_URL=

# Authentication
AUTH_SECRET=

# OAuth Providers
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Product Repository Mode
# Options: STATIC | PRISMA | AUTO
# STATIC: Force use of StaticProductRepository
# PRISMA: Force use of PrismaProductRepository (fail fast on errors)
# AUTO: Try PrismaProductRepository, fallback to StaticProductRepository on errors
PRODUCT_REPOSITORY_MODE=
